<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-test
  xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0_v1p0.xsd"
  identifier="TEST-feedback-maxattempts"
  title="Part feedback with maxAttempts=2">

  <qti-outcome-declaration identifier="PART_RESULT" base-type="identifier" cardinality="single"/>

  <qti-test-part identifier="TP1" navigation-mode="linear" submission-mode="individual">
    <qti-item-session-control max-attempts="2"/>
    <qti-assessment-section identifier="S1" title="Section 1" visible="true">
      <qti-assessment-item-ref identifier="Q1" href="q-1pt.xml"/>
    </qti-assessment-section>
    <qti-test-feedback identifier="PART_DONE" outcome-identifier="PART_RESULT" show-hide="show" access="atEnd">
      <qti-content-body>Part complete.</qti-content-body>
    </qti-test-feedback>
  </qti-test-part>

  <qti-outcome-processing>
    <qti-set-outcome-value identifier="PART_RESULT">
      <qti-base-value base-type="identifier">PART_DONE</qti-base-value>
    </qti-set-outcome-value>
  </qti-outcome-processing>
</qti-assessment-test>
