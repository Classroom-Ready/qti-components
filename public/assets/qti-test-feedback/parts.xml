<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-test
  xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0_v1p0.xsd"
  identifier="TEST-feedback-parts"
  title="Two-part test with part-scoped and test-scoped feedback">

  <qti-outcome-declaration identifier="PART1_RESULT" base-type="identifier" cardinality="single"/>
  <qti-outcome-declaration identifier="TEST_RESULT" base-type="identifier" cardinality="single"/>

  <qti-test-part identifier="TP1" navigation-mode="linear" submission-mode="individual">
    <qti-assessment-section identifier="S1" title="Section 1" visible="true">
      <qti-assessment-item-ref identifier="P1Q1" href="q-1pt.xml"/>
    </qti-assessment-section>
    <qti-test-feedback identifier="PART1_DONE" outcome-identifier="PART1_RESULT" show-hide="show" access="atEnd">
      <qti-content-body>Part 1 complete.</qti-content-body>
    </qti-test-feedback>
  </qti-test-part>

  <qti-test-part identifier="TP2" navigation-mode="linear" submission-mode="individual">
    <qti-assessment-section identifier="S2" title="Section 2" visible="true">
      <qti-assessment-item-ref identifier="P2Q1" href="q-1pt.xml"/>
    </qti-assessment-section>
  </qti-test-part>

  <qti-outcome-processing>
    <qti-set-outcome-value identifier="PART1_RESULT">
      <qti-base-value base-type="identifier">PART1_DONE</qti-base-value>
    </qti-set-outcome-value>
    <qti-set-outcome-value identifier="TEST_RESULT">
      <qti-base-value base-type="identifier">TEST_DONE</qti-base-value>
    </qti-set-outcome-value>
  </qti-outcome-processing>

  <qti-test-feedback identifier="TEST_DONE" outcome-identifier="TEST_RESULT" show-hide="show" access="atEnd">
    <qti-content-body>Test complete.</qti-content-body>
  </qti-test-feedback>
</qti-assessment-test>
