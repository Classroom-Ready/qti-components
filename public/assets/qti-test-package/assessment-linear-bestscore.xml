<?xml version="1.0" encoding="utf-8"?>
<qti-assessment-test
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0_v1p0.xsd"
        identifier="LinearBestScore"
        title="Linear navigation gated on best score"
        xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0"
>
    <!-- Linear/individual, up to two attempts, so a sub-maximum score leaves an
         attempt available and must NOT unlock Next. -->
    <qti-test-part identifier="test-part-1" navigation-mode="linear" submission-mode="individual">
        <qti-item-session-control max-attempts="2" allow-skipping="false" />
        <qti-assessment-section identifier="section-1" title="Section 1" visible="true">
            <!-- Mapping-scored: "best" must be SCORE === MAXSCORE, not an exact
                 correct-response match (GLAD also scores full marks). -->
            <qti-assessment-item-ref identifier="ITM-choice_mapping" href="items/choice_mapping.xml" />
            <!-- Trailing item so the mapping item isn't the last one. -->
            <qti-assessment-item-ref identifier="ITM-text_entry" href="items/text_entry.xml" />
        </qti-assessment-section>
    </qti-test-part>
</qti-assessment-test>
